      "settings": {
        "custom_liquid": "<div id=\"custom-countdown-wrapper\">\n  <div id=\"custom-countdown\">\n    <div class=\"countdown-box\" id=\"timer\">\n      <div class=\"time-part\"><span id=\"days\">00</span><small>Days</small></div>\n      <div class=\"time-part\"><span id=\"hours\">00</span><small>Hours</small></div>\n      <div class=\"time-part\"><span id=\"minutes\">00</span><small>Min</small></div>\n      <div class=\"time-part\"><span id=\"seconds\">00</span><small>Sec</small></div>\n    </div>\n  </div>\n</div>\n\n<style>\n#custom-countdown-wrapper {\n  width: 100%;\n  padding: 20px 0;\n  display: flex;\n  justify-content: center;\n}\n\n.countdown-box {\n  display: flex;\n  gap: 15px;\n}\n\n.countdown-box .time-part {\n  background: #fff;\n  color: #000;\n  font-family: monospace;\n  padding: 10px 16px;\n  border-radius: 10px;\n  text-align: center;\n  min-width: 80px;\n}\n\n.countdown-box span {\n  display: block;\n  font-size: 2.2rem;\n  font-weight: bold;\n}\n\n.countdown-box small {\n  display: block;\n  margin-top: 5px;\n  font-size: 1.1rem;\n  text-transform: uppercase;\n  font-weight: bold;\n}\n\n@media screen and (max-width: 480px) {\n  .countdown-box {\n    gap: 8px;\n  }\n  .countdown-box .time-part {\n    min-width: 60px;\n    padding: 8px 10px;\n  }\n  .countdown-box span {\n    font-size: 1.5rem;\n  }\n  .countdown-box small {\n    font-size: 0.8rem;\n  }\n}\n</style>\n\n<script>\n  (function() {\n    // Updated to the NEXT Friday: April 17, 2026, at 6:00 PM\n    const endDate = new Date(\"Apr 17, 2026 18:00:00\").getTime();\n    \n    const daysEl = document.getElementById(\"days\");\n    const hoursEl = document.getElementById(\"hours\");\n    const minutesEl = document.getElementById(\"minutes\");\n    const secondsEl = document.getElementById(\"seconds\");\n\n    const timer = setInterval(() => {\n      const now = new Date().getTime();\n      const distance = endDate - now;\n\n      if (distance <= 0) {\n        clearInterval(timer);\n        document.getElementById(\"custom-countdown\").innerHTML = \"<h2 style='color:#fff;'>WE ARE LIVE!</h2>\";\n      } else {\n        const days = Math.floor(distance / (1000 * 60 * 60 * 24));\n        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));\n        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));\n        const seconds = Math.floor((distance % (1000 * 60)) / 1000);\n\n        daysEl.textContent = String(days).padStart(2, '0');\n        hoursEl.textContent = String(hours).padStart(2, '0');\n        minutesEl.textContent = String(minutes).padStart(2, '0');\n        secondsEl.textContent = String(seconds).padStart(2, '0');\n      }\n    }, 1000);\n  })();\n</script>",
